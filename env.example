# --- SigNoz Cloud (MCP is the ONLY data path — see Section 1 of the build spec) ---
SIGNOZ_INSTANCE_URL=
SIGNOZ_MCP_URL=
SIGNOZ_API_KEY=

# --- otel-griptape export target (direct OTLP from the demo app, NOT via MCP) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=

# --- Guardian LLM reasoning layer (Section 4.3.3) ---
LLM_PROVIDER=openai        # or "ollama"
OPENAI_API_KEY=
OPENAI_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Guardian service ---
AUDIT_INTERVAL_MINUTES=10
FASTAPI_PORT=8000

# --- Fallback (only if Stage 0 gate fails and you switch to self-hosted SigNoz) ---
SIGNOZ_SELF_HOSTED=false
SIGNOZ_SELF_HOSTED_URL=http://localhost:3301
