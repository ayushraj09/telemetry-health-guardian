# --- SigNoz Cloud (MCP is the ONLY data path — see Section 1 of the build spec) ---
SIGNOZ_INSTANCE_URL=
SIGNOZ_MCP_URL=
SIGNOZ_API_KEY=

# --- otel-griptape export target (direct OTLP from the demo app, NOT via MCP) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=

# --- Guardian LLM reasoning layer (Section 4.3.3) ---
LLM_PROVIDER=openai        # or "ollama"
OPENAI_API_KEY=
OPENAI_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Guardian service ---
AUDIT_INTERVAL_MINUTES=10
FASTAPI_PORT=8000
# Comma-separated SigNoz service names to audit each cycle. Empty/unset =
# one combined audit across all services (service=None), the default this
# project's single demo-agent-app target uses.
AUDIT_SERVICES=
# Relative SigNoz query window each audit cycle covers, e.g. 15m/1h/24h.
AUDIT_WINDOW=1h
# Webhook URL for the Section 4.5 alerts' notification channel. If unset,
# main.py skips alert provisioning at startup (run
# experiments/test_stage6.py --provision-alerts manually instead).
GUARDIAN_ALERT_WEBHOOK_URL=

# --- Stage 7 frontend (Section 4.6) ---
# Base URL of guardian/main.py's FastAPI backend, for frontend/app.py.
GUARDIAN_API_URL=http://localhost:8000

# --- Stage 8: citation_service.py (R7) ---
# demo-agent-app/fact_check_and_cite.py's base URL for the outbound
# citation-lookup call to citation_service.py -- must match whatever port
# citation_service.py is actually started on (see its own module
# docstring: `uvicorn citation_service:app --port 8100`). Runs as its own
# separate process, not started by demo-agent-app/app.py.
CITATION_SERVICE_URL=http://localhost:8100
CITATION_SERVICE_PORT=8100
# How long fact_check_and_cite.py waits on one citation lookup before
# giving up and degrading to an empty citation (see _fetch_citation).
CITATION_SERVICE_TIMEOUT_SECONDS=15.0

# --- Stage 8 rework: ollama_r6.py (R6) ---
# How long ollama_r6.py's direct HTTP call to Ollama's /api/chat waits
# before giving up and degrading that one claim to "unclear" (mirrors
# CITATION_SERVICE_TIMEOUT_SECONDS's role above). Uses OLLAMA_BASE_URL
# above -- same Ollama instance the Guardian's LLM_PROVIDER=ollama option
# would use, just a different call site.
OLLAMA_R6_TIMEOUT_SECONDS=60.0

# --- Fallback (only if Stage 0 gate fails and you switch to self-hosted SigNoz) ---
# guardian/mcp_client.py::SignozMCPClient reads SIGNOZ_MCP_MODE directly
# ("cloud" [default] or "selfhost") -- set it to "selfhost" to switch, and
# point SIGNOZ_MCP_URL above at your self-hosted signoz-mcp-server instead
# (defaults to http://localhost:8000/mcp if unset in that mode).
SIGNOZ_MCP_MODE=cloud
# Only read in "cloud" mode, to build the default
# https://mcp.<region>.signoz.cloud/mcp URL when SIGNOZ_MCP_URL is unset.
SIGNOZ_CLOUD_REGION=us
